{
  "name": "family-tree-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev -- next dev",
    "build": "next build",
    "deploy": "npm run build && wrangler pages deploy .vercel/output/static",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv env.d.ts",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "migrate:local": "wrangler d1 execute family-tree-db --local --file=migrations/0001_initial.sql",
    "migrate:remote": "wrangler d1 execute family-tree-db --file=migrations/0001_initial.sql",
    "import:local": "wrangler d1 execute family-tree-db --local --file=migrations/0002_import.sql",
    "import:remote": "wrangler d1 execute family-tree-db --file=migrations/0002_import.sql"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1",
    "@cloudflare/workers-types": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3",
    "typescript": "^5",
    "wrangler": "^4.81.1"
  }
}
